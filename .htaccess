# Disable MultiViews to prevent conflicts with clean URLs
Options -MultiViews -Indexes

RewriteEngine On
RewriteBase /

# 1. Force HTTPS (Robust version for institutional/shared hosting)
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. Sitemap & Robots
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# 3. Exclude Admin & Assets
RewriteRule ^(admin|assets|uploads|ajax|css|js)(/.*)?$ - [L]

# 3. Remove trailing slash (except for directories)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} ^/(.+)/$
RewriteRule ^(.+)/$ /$1 [L,R=301]

# 4. Redirect .php extensions to extensionless (External Redirect)
RewriteCond %{THE_REQUEST} \s/+(.+)\.php[\s?] [NC]
RewriteRule ^(.+)\.php$ /$1 [L,R=301]

# 5. Article Detail Pretty URLs: /article/ID/slug
RewriteRule ^article/([0-9]+)/?([^/]*)$ article.php?id=$1 [QSA,L]

# 6. Event Detail Pretty URLs: /event/ID/slug
RewriteRule ^event/([0-9]+)/?([^/]*)$ event_details.php?id=$1 [QSA,L]

# 7. Category Filter Pretty URLs: /category/Name
RewriteRule ^category/([^/]+)$ events.php?category=$1 [QSA,L]

# 7b. Document Detail Pretty URLs: /document/ID
RewriteRule ^document/([0-9]+)$ document.php?id=$1 [QSA,L]

# 8. Internal Rewrite for extensionless PHP files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^/]+)$ $1.php [L]