# Basic SIKS .htaccess
Options -Indexes
Options -MultiViews

# Ensure index.php is the default
DirectoryIndex index.php

# Increase limits for uploads
<IfModule mod_php.c>
    php_value upload_max_filesize 25M
    php_value post_max_size 50M
</IfModule>

RewriteEngine On
RewriteBase /

# 1. Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. Remove Trailing Slashes (SEO best practice)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# 3. 301 Redirect old .php URLs to clean ones (Prevent duplicate content)
# Check if the actual request ends in .php (but avoid redirecting actual index.php internally)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+(.+)\.php[\s?] [NC]
RewriteRule ^(.+)\.php$ /$1 [R=301,L]

# 4. Article Detail Routing: /article/ID/slug
RewriteRule ^article/([0-9]+)/? article.php?id=$1 [L,QSA]

# 5. Event Detail Routing: /event/ID/slug
RewriteRule ^event/([0-9]+)/? event_details.php?id=$1 [L,QSA]

# 6. Category Routing: /category/community
RewriteRule ^category/([^/]+)/? events.php?category=$1 [L,QSA]

# 7. Internal Mapping for clean URLs (e.g. /about -> about.php)
# If the file doesn't exist but the .php version does, serve it internally
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^/]+)$ $1.php [L]
